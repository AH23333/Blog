---
import BaseLayout from "../base/BaseLayout.astro";

type Props = {
  title?: string;
  tabTitle?: string;
  description?: string;
  preloadCjk?: boolean;
  pageType?: "website" | "article";
  publishedTime?: Date;
};
---

<BaseLayout
  title={Astro.props.title}
  tabTitle={Astro.props.tabTitle}
  description={Astro.props.description}
  preloadCjk={Astro.props.preloadCjk}
  pageType={Astro.props.pageType}
  publishedTime={Astro.props.publishedTime}
>
  <!-- 返回按钮 -->
  <button id="nav-back" class="nav-btn" type="button" aria-label="返回上一页" title="返回上一页">
    &#x2190; BACK
  </button>

  <!-- 返回顶部按钮 -->
  <button id="scroll-top" class="nav-btn" type="button" aria-label="返回顶部" title="返回顶部">
    &#x2191; TOP
  </button>

  <main class="screen">
    <slot />
  </main>
</BaseLayout>

<script>
  // 返回上一页（首页隐藏）
  const backBtn = document.getElementById("nav-back");
  if (backBtn) {
    // 首页路径为 "/"（Astro 的 base 为 "/"）
    if (window.location.pathname === "/") {
      backBtn.style.display = "none";
    }

    backBtn.addEventListener("click", () => {
      if (document.referrer && new URL(document.referrer).origin === window.location.origin) {
        window.history.back();
      } else {
        window.location.href = "/";
      }
    });
  }

  // 返回顶部
  const topBtn = document.getElementById("scroll-top");
  if (topBtn) {
    const checkScroll = () => {
      topBtn.classList.toggle("visible", window.scrollY > 300);
    };

    window.addEventListener("scroll", checkScroll, { passive: true });
    checkScroll();

    topBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>

  <script>
  // UNIX 光标打字动画 — 逐行显示 + 闪烁光标
  function initTypewriter() {
    const preElements = document.querySelectorAll(".textmode-pre");
    if (preElements.length === 0) return;

    const allLines: { el: HTMLElement; lineHtml: string }[] = [];

    for (const pre of preElements) {
      const preEl = pre as HTMLElement;
      if (preEl.hasAttribute("data-typed")) continue;
      preEl.setAttribute("data-typed", "true");

      // 跳过自身标记为 no-typewriter 的元素
      if (preEl.hasAttribute("data-no-typewriter")) {
        preEl.style.visibility = "visible";
        continue;
      }

      const originalHtml = preEl.innerHTML;
      if (!originalHtml.trim()) {
        preEl.style.visibility = "visible";
        continue;
      }

      // 保护 data-no-typewriter 子元素：利用 DOM 解析找到它们，用占位符替换
      // 这样可以避免分行时破坏其 HTML 结构（如 <pre><code> 内的多行内容）
      const noTypewriterBlocks: string[] = [];
      let protectedHtml = originalHtml;

      // 用临时 DOM 找出所有 data-no-typewriter 元素
      const tmp = document.createElement("div");
      tmp.innerHTML = originalHtml;
      const blocks = tmp.querySelectorAll("[data-no-typewriter]");
      for (const block of blocks) {
        const outer = block.outerHTML;
        const idx = noTypewriterBlocks.length;
        noTypewriterBlocks.push(outer);
        protectedHtml = protectedHtml.replace(outer, `\uE400NT${idx}\uE400`);
      }

      let lines: string[];

      // <div> 元素：浏览器 innerHTML 不保留 \n → 使用 DOM 分行
      if (preEl.tagName === "DIV") {
        const domTmp = document.createElement("div");
        domTmp.innerHTML = protectedHtml;
        lines = [];

        const BLOCK_TAGS = /^(p|h[1-6]|ul|ol|li|blockquote|table|hr|div|pre|figure|figcaption|dl|dt|dd|section|header|footer|main|article|nav|aside)$/;

        function walk(node: Node): void {
          if (node.nodeType === Node.TEXT_NODE) {
            const text = node.textContent || "";
            if (text.trim()) {
              const parts = text.split("\n");
              for (const part of parts) {
                lines.push(part);
              }
            }
          } else if (node.nodeType === Node.ELEMENT_NODE) {
            const el = node as HTMLElement;
            if (BLOCK_TAGS.test(el.tagName.toLowerCase())) {
              lines.push(el.outerHTML);
            } else {
              for (const child of node.childNodes) {
                walk(child);
              }
            }
          }
        }

        for (const child of domTmp.childNodes) {
          walk(child);
        }
      } else {
        // <pre> 元素：直接按 \n 拆分
        lines = protectedHtml.split("\n");
      }

      preEl.innerHTML = "";

      for (const lineHtml of lines) {
        // 恢复被保护的 data-no-typewriter 元素
        let restored = lineHtml;
        for (let i = 0; i < noTypewriterBlocks.length; i++) {
          restored = restored.replaceAll(`\uE400NT${i}\uE400`, noTypewriterBlocks[i]);
        }
        allLines.push({ el: preEl, lineHtml: restored });
      }
    }

    if (allLines.length === 0) return;

    let currentIndex = 0;
    // 自适应批处理：每批至少 2 行，页面越长每批行数越多
    const batchSize = Math.max(2, Math.min(8, Math.floor(allLines.length / 200)));
    const interval = 20;

    const cursor = document.createElement("span");
    cursor.className = "typewriter-cursor";
    cursor.textContent = "\u2588";
    cursor.setAttribute("aria-hidden", "true");

    function typeNextBatch() {
      const batch = allLines.slice(currentIndex, currentIndex + batchSize);

      if (batch.length === 0) {
        cursor.remove();
        return;
      }

      for (const { el, lineHtml } of batch) {
        const existingCount = el.querySelectorAll(".tw-line").length;
        const lineSpan = document.createElement("span");
        lineSpan.className = "tw-line";
        // 空行使用 &nbsp; 确保空白行高度保留
        lineSpan.innerHTML = lineHtml || "&nbsp;";

        if (existingCount > 0) {
          el.appendChild(document.createTextNode("\n"));
        } else {
          // 第一个文字行出现时再显示该 pre，避免空白闪烁
          el.style.visibility = "visible";
        }
        el.appendChild(lineSpan);

        // 光标跟随当前文字行
        lineSpan.appendChild(cursor);
      }

      currentIndex += batch.length;

      if (currentIndex < allLines.length) {
        window.setTimeout(typeNextBatch, interval);
      } else {
        cursor.remove();
      }
    }

    // 延迟启动，确保 DOM 就绪
    window.setTimeout(typeNextBatch, 150);
  }

  if (document.readyState === "complete") {
    window.setTimeout(initTypewriter, 50);
  } else {
    window.addEventListener("load", () => {
      window.setTimeout(initTypewriter, 50);
    }, { once: true });
  }
</script>

<style is:global>
  /* 初始隐藏文本内容，防止打字动画前的闪烁 */
  .textmode-pre {
    visibility: hidden;
  }

  /* 导航按钮通用样式 */
  .nav-btn {
    position: fixed;
    z-index: 100;
    padding: 4px 10px;
    border: 1px solid var(--ansi-bright-black);
    background: var(--bg);
    color: var(--ansi-cyan);
    font-family: var(--text-font);
    font-size: var(--text-size);
    line-height: 1;
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s, border-color 0.2s;
  }

  .nav-btn:hover {
    opacity: 1;
    border-color: var(--link);
    color: var(--link);
    background: var(--link-hover-bg);
  }

  .nav-btn:focus-visible {
    opacity: 1;
    outline: 1px solid var(--link);
    outline-offset: 2px;
  }

  /* 返回按钮 - 左上角 */
  #nav-back {
    top: 8px;
    left: 8px;
  }

  /* 返回顶部按钮 - 右下角 */
  #scroll-top {
    bottom: 12px;
    right: 12px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  #scroll-top.visible {
    opacity: 0.6;
    pointer-events: auto;
  }

  #scroll-top.visible:hover {
    opacity: 1;
  }

  /* 打字机光标 */
  .typewriter-cursor {
    display: inline;
    color: var(--link);
    animation: cursor-blink 0.8s step-end infinite;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* 打字行淡入效果 */
  .tw-line {
    animation: line-fade-in 0.05s ease-out;
  }

  @keyframes line-fade-in {
    from { opacity: 0.3; }
    to { opacity: 1; }
  }
</style>